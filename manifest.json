{
  "manifest_version": 3,
  "name": "TabLens",
  "version": "0.2.0",
  "description": "Manage and understand all your open tabs in one place.",
  "permissions": ["tabs", "tabGroups", "storage", "alarms"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Open TabLens"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
